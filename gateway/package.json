{
  "name": "@agritrade/gateway",
  "version": "1.0.0",
  "description": "AgriTrade API Gateway",
  "main": "src/index.js",
  "scripts": {
    "start":       "node src/index.js",
    "dev":         "nodemon src/index.js",
    "build":       "echo 'Gateway has no build step (plain Node)'",
    "test":        "jest --forceExit --detectOpenHandles",
    "test:watch":  "jest --watch",
    "lint":        "eslint src/**/*.js",
    "lint:fix":    "eslint src/**/*.js --fix"
  },
  "dependencies": {
    "compression":          "^1.7.4",
    "cors":                 "^2.8.5",
    "dotenv":               "^16.4.5",
    "express":              "^4.19.2",
    "express-rate-limit":   "^7.3.1",
    "helmet":               "^7.1.0",
    "hpp":                  "^0.2.3",
    "ioredis":              "^5.4.1",
    "joi":                  "^17.13.1",
    "jsonwebtoken":         "^9.0.2",
    "morgan":               "^1.10.0",
    "rate-limit-redis":     "^4.2.0",
    "uuid":                 "^10.0.0",
    "winston":              "^3.13.0",
    "xss":                  "^1.0.15",
    "http-proxy-middleware": "^3.0.2"
  },
  "devDependencies": {
    "eslint":               "^9.6.0",
    "jest":                 "^29.7.0",
    "nodemon":              "^3.1.4",
    "supertest":            "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
