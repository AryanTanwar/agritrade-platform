# ─────────────────────────────────────────────────────────────────────────────
# AgriTrade Platform — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development            # development | production | test
APP_PORT=3000
APP_NAME=AgriTrade
APP_URL=https://agritrade.example.com
LOG_LEVEL=info                  # error | warn | info | debug

# ── API Gateway ───────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_RATE_LIMIT_MAX=100

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_min_64_char_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_different_min_64_char_random_string
JWT_REFRESH_EXPIRES_IN=7d

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agritrade
DB_USER=agritrade_app
DB_PASSWORD=CHANGE_ME_strong_password
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_password
REDIS_TLS=true

# ── Encryption (AES-256) ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AES_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars
AES_IV_LENGTH=16

# ── Hyperledger Fabric ────────────────────────────────────────────────────────
FABRIC_CHANNEL_NAME=agritrade-channel
FABRIC_CHAINCODE_NAME=agritrade
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_CA_URL=https://localhost:7054
FABRIC_WALLET_PATH=./wallet
FABRIC_ORG_MSP=FarmersMSP
FABRIC_ADMIN_ID=admin
FABRIC_ADMIN_SECRET=CHANGE_ME

# ── Payment Gateway ───────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

# ── IPFS / File Storage ───────────────────────────────────────────────────────
IPFS_API_URL=http://localhost:5001
AWS_REGION=ap-south-1
AWS_S3_BUCKET=agritrade-docs
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ── Notification Services ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@agritrade.example.com
FCM_SERVER_KEY=CHANGE_ME

# ── Vault (HashiCorp) ────────────────────────────────────────────────────────
VAULT_ADDR=https://vault.agritrade.internal:8200
VAULT_TOKEN=CHANGE_ME           # Use AppRole in production, not root token
VAULT_MOUNT_PATH=secret/agritrade

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://agritrade.example.com,https://admin.agritrade.example.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_min_64_char_random_string
SESSION_MAX_AGE=900000          # 15 minutes in ms

# ── Logistics 3PL ────────────────────────────────────────────────────────────
LOGISTICS_API_KEY=CHANGE_ME
LOGISTICS_WEBHOOK_SECRET=CHANGE_ME
LOGISTICS_API_BASE_URL=https://api.3pl-partner.example.com/v1

# ── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
SENTRY_DSN=CHANGE_ME
